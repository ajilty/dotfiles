# SSH over Cloudflare Tunnel, with automatic direct fallback.
# Try the tunnel first; if cloudflared can't reach the edge (no Access app,
# tunnel down, or a direct-only host like home.ajilty.com that's port-forwarded
# for mosh), fall back to a direct TCP connect to %h:%p.
Host *.ajilty.com
    ProxyCommand sh -c 'cloudflared access ssh --hostname %h 2>/dev/null || nc %h %p'
