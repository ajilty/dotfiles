# Example env preset
# Copy this file and rename to <name>.env to create a new preset.
# It will auto-register as: env-<preset>
#
# Run `env` to list all available presets.
# Run `env <preset>` or `env-<preset>` to load a preset.
#
# Lines are standard shell export statements. Values containing
# op:// references are resolved at runtime via `op inject`.
#
# Set OP_ACCOUNT to skip the 1Password account selection prompt:
# export OP_ACCOUNT=my.1password.com
#
# Plain values (no op needed):
# export MY_APP_ENV=production
# export MY_APP_REGION=us-east-1
#
# 1Password secret references:
# export MY_APP_API_KEY=op://VaultName/ItemName/FieldName
# export MY_APP_DB_PASSWORD=op://VaultName/Database/password
