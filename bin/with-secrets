#!/usr/bin/env sh
# with-secrets — run a command with a named env preset injected.
#
#   with-secrets <preset> [--] <command> [args...]
#
# Looks up <preset>.env and execs <command> with that preset's variables in its
# environment, resolving any op:// references via 1Password along the way.
#
# Preset lookup (work-specific overrides reusable):
#   1. ~/.local/config/shell/env.d/<preset>.env   (work / Stone Ridge, untracked)
#   2. ~/.config/shell/env.d/<preset>.env         (reusable / personal, tracked)
#
# This is the spawn-time companion to the `env <preset>` shell function in
# functions.d/env.sh, which sources the *same* files into your current shell.
# One preset file, two verbs:  `env` sources it;  `with-secrets` runs a child
# with it. The bin form exists because MCP hosts (and cron, etc.) spawn a
# command on PATH and cannot call a shell function.
#
# Backend is 1Password (`op run`) for now. To switch managers, change the one
# exec line below (e.g. `doppler run --`, `bws run --`, `sops exec-env`).
set -eu

prog=$(basename "$0")
if [ "$#" -lt 2 ]; then
	echo "usage: $prog <preset> [--] <command> [args...]" >&2
	exit 64
fi

preset=$1
shift
[ "${1:-}" = "--" ] && shift
if [ "$#" -lt 1 ]; then
	echo "$prog: no command given for preset '$preset'" >&2
	exit 64
fi

env_file=""
for d in "$HOME/.local/config/shell/env.d" "$HOME/.config/shell/env.d"; do
	if [ -f "$d/$preset.env" ]; then
		env_file="$d/$preset.env"
		break
	fi
done
if [ -z "$env_file" ]; then
	echo "$prog: no env preset '$preset'" >&2
	echo "  looked in: $HOME/.local/config/shell/env.d/$preset.env" >&2
	echo "             $HOME/.config/shell/env.d/$preset.env" >&2
	exit 1
fi

exec op run --no-masking --env-file="$env_file" -- "$@"
