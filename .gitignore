# Ignores for the dotfiles repository
# To modify global ignore configuration, edit ~/.config/git/ignore
.dotfiles
# Local test sandboxes
/test/sandbox-*
*
# ...except the shared agent-skills tree, so new skills installed via
# `skills add` show up in `git status` automatically.
!.agents/
!.agents/**
# Also un-ignore the homegrown skills authoring root (~/skills/).
# These are published via `npx skills add ~/skills -s <name>` into
# ~/.agents/skills/ for local use, and can be pushed to a standalone
# repo for distribution.
!skills/
!skills/**
# Re-ignore noise that lands inside the un-ignored .agents/ tree.
# (Repo-level `*` short-circuits global ignores, so this can't live in
# ~/.config/git/ignore for files under .agents/.)
.agents/**/.DS_Store
.agents/**/__pycache__/
skills/**/.DS_Store
# Skill authoring workspaces (eval artifacts, drafts, snapshots) stay
# local — only ~/skills/<name>/ sources are tracked (see skills/README.md).
skills/*-workspace/
# Re-ignore homegrown skills under .agents/skills/ — they're locally
# installed by `npx skills add ~/skills -s <name>` from the authoritative
# copy in ~/skills/<name>/. Adding a new homegrown skill? Add it here.
.agents/skills/dotfiles-repo/
.agents/skills/asking-user-questions/
.agents/skills/grill-me/
