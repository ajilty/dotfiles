#!/usr/bin/env bash
# Identity allowlist for the dotfiles repo.
# Activated by core.hooksPath in ~/.config/git/dotfiles.config (via includeIf).
# Refuses any commit whose author or committer is not the expected identity.
set -euo pipefail

EXPECTED="ajilty <github@ajilty.com>"

# `git var GIT_AUTHOR_IDENT` returns "Name <email> timestamp tz".
# Strip the trailing " <timestamp> <tz>" to leave "Name <email>".
strip_time() {
    local ident="$1"
    echo "${ident% * *}"
}

check() {
    local label="$1" who
    who=$(strip_time "$2")
    if [[ "$who" != "$EXPECTED" ]]; then
        echo "ERROR: dotfiles identity guard tripped — commit blocked." >&2
        echo "  $label:   $who" >&2
        echo "  Expected: $EXPECTED" >&2
        echo "" >&2
        echo "Identity for this repo should come from the includeIf block in" >&2
        echo "~/.config/git/config (matched on gitdir:~/.dotfiles)." >&2
        echo "If you're seeing this, GIT_DIR may not be set, or the include" >&2
        echo "isn't matching. Check: git config --show-origin user.email" >&2
        exit 1
    fi
}

check "Author"    "$(git var GIT_AUTHOR_IDENT)"
check "Committer" "$(git var GIT_COMMITTER_IDENT)"

# ---------------------------------------------------------------------------
# Content guard: scan staged diff against a local, never-tracked blocklist.
# Blocklist is fetched from a private gist via `dotfiles-blocklist-sync`.
# Missing file -> warn, don't block (bootstrap-safe on fresh machines).
# Stale file   -> warn, scan anyway.
# Pattern hit  -> block.
# ---------------------------------------------------------------------------

BLOCKLIST_FILE="$HOME/.local/config/dotfiles/blocklist"
STALE_DAYS=30

warn() { echo "WARN: $*" >&2; }

if [[ ! -f "$BLOCKLIST_FILE" ]]; then
    warn "dotfiles blocklist not initialized on this machine."
    warn "  Run \`dotfiles-blocklist-sync\` to fetch it. Skipping content scan."
    exit 0
fi

if [[ -n "$(find "$BLOCKLIST_FILE" -mtime +"$STALE_DAYS" -print 2>/dev/null)" ]]; then
    warn "dotfiles blocklist is more than $STALE_DAYS days old."
    warn "  Run \`dotfiles-blocklist-sync\` to refresh. Scanning with stale list."
fi

# Read non-blank, non-comment patterns into an array.
patterns=()
while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    patterns+=("$line")
done < "$BLOCKLIST_FILE"

if [[ ${#patterns[@]} -eq 0 ]]; then
    warn "dotfiles blocklist is present but contains no patterns."
    exit 0
fi

# Capture the staged diff once. -U0 keeps only changed lines + headers.
diff_output=$(git diff --cached --no-color -U0)
if [[ -z "$diff_output" ]]; then
    exit 0
fi

# Only scan ADDED lines. Removing a leak from a tracked file is the workflow
# we want to encourage, so a `-` line matching a pattern must not block.
# Also strip the +++ header lines so paths in file headers don't false-match.
content=$(echo "$diff_output" | grep -E '^\+' | grep -v '^+++' || true)

hits=()
for pattern in "${patterns[@]}"; do
    if echo "$content" | grep -qiF -- "$pattern"; then
        hits+=("$pattern")
    fi
done

if [[ ${#hits[@]} -gt 0 ]]; then
    echo "ERROR: dotfiles content guard tripped — commit blocked." >&2
    echo "  The staged diff matches blocklist patterns:" >&2
    for p in "${hits[@]}"; do
        echo "    - $p" >&2
    done
    echo "" >&2
    echo "Affected files:" >&2
    echo "$diff_output" | grep -E '^\+\+\+ b/' | sed 's|^+++ b/|    |' >&2
    echo "" >&2
    echo "Edit the staged content or unstage the file. To inspect the blocklist:" >&2
    echo "  cat $BLOCKLIST_FILE" >&2
    exit 1
fi
